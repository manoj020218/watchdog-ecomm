{
  "name": "@commerce-watchdog/web-sdk",
  "version": "1.0.0",
  "description": "Lightweight browser SDK for Commerce Watchdog — embed on any e-commerce site",
  "main": "./dist/sdk.js",
  "module": "./dist/sdk.mjs",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk.mjs",
      "require": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@commerce-watchdog/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
