{
  "name": "commerce-watchdog",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone e-commerce order pipeline watchdog — monitor, detect failures, and auto-recover",
  "scripts": {
    "dev:api": "pnpm --filter @commerce-watchdog/api dev",
    "dev:dashboard": "pnpm --filter @commerce-watchdog/dashboard dev",
    "build": "pnpm -r build",
    "build:sdk": "pnpm --filter @commerce-watchdog/web-sdk build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "engines": { "node": ">=20" }
}
